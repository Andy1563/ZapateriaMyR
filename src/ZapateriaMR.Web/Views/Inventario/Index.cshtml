@model ZapateriaMR.Web.ViewModels.Inventario.InventarioIndexViewModel

@{
    ViewData["Title"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Inventario</h1>
        <p class="text-muted mb-0">Controla existencias, stock bajo y movimientos de productos.</p>
    </div>

    <a asp-controller="Productos" asp-action="Create" class="btn btn-primary rounded-pill px-4">
        Nuevo producto
    </a>
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-center">
            <div class="col-md-9">
                <input asp-for="Busqueda"
                       class="form-control form-control-lg rounded-pill"
                       placeholder="Buscar por SKU, producto o marca..." />
            </div>

            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-dark btn-lg rounded-pill">
                    Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <span class="text-muted small">Productos en inventario</span>
                <h3 class="fw-bold mb-0">@Model.Productos.Count</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <span class="text-muted small">Productos con stock bajo</span>
                <h3 class="fw-bold text-danger mb-0">@Model.Productos.Count(p => p.StockBajo)</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <span class="text-muted small">Unidades disponibles</span>
                <h3 class="fw-bold mb-0">@Model.Productos.Sum(p => p.CantidadDisponible)</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        @if (!Model.Productos.Any())
        {
            <div class="text-center py-5">
                <h5 class="fw-semibold">No hay productos en inventario</h5>
                <p class="text-muted">Registra productos para comenzar a administrar existencias.</p>
                <a asp-controller="Productos" asp-action="Create" class="btn btn-primary rounded-pill px-4">
                    Crear producto
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Producto</th>
                            <th>SKU</th>
                            <th>Categoría</th>
                            <th>Disponible</th>
                            <th>Reservado</th>
                            <th>Stock mínimo</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Productos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrWhiteSpace(item.ImagenUrl))
                                        {
                                            <img src="@item.ImagenUrl"
                                                 alt="@item.NombreProducto"
                                                 class="product-thumb" />
                                        }
                                        else
                                        {
                                            <div class="product-thumb-placeholder">
                                                @item.NombreProducto.Substring(0, 1).ToUpper()
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-semibold">@item.NombreProducto</div>
                                            <div class="text-muted small">
                                                @item.Marca
                                                @if (!string.IsNullOrWhiteSpace(item.Color))
                                                {
                                                    <span> · @item.Color</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.Talla))
                                                {
                                                    <span> · Talla @item.Talla</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge text-bg-light border">@item.CodigoSku</span>
                                </td>

                                <td>@item.Categoria</td>

                                <td class="fw-bold">@item.CantidadDisponible</td>

                                <td>@item.CantidadReservada</td>

                                <td>@item.StockMinimo</td>

                                <td>
                                    @if (item.StockBajo)
                                    {
                                        <span class="badge rounded-pill text-bg-danger">Stock bajo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill text-bg-success">Correcto</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="product-actions">
                                        <a asp-action="Details"
                                           asp-route-productoId="@item.ProductoId"
                                           class="btn-product-action action-view">
                                            Ver
                                        </a>

                                        <a asp-action="RegistrarMovimiento"
                                           asp-route-productoId="@item.ProductoId"
                                           class="btn-product-action action-edit">
                                            Movimiento
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>