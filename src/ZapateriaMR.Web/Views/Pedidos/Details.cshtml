@model ZapateriaMR.Application.DTOs.Pedidos.PedidoDetalleDto
@using ZapateriaMR.Domain.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Detalle de pedido";
    var estados = ViewBag.Estados as IEnumerable<SelectListItem> ?? [];
}

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">@Model.NumeroPedido</h1>
        <p class="text-muted mb-0">Detalle completo del pedido.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        Volver
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <span class="badge text-bg-light border mb-2">@Model.NumeroPedido</span>
                        <h3 class="fw-bold mb-1">@Model.NombreCliente</h3>
                        <p class="text-muted mb-0">
                            @Model.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>

                    @if (Model.Estado == EstadoPedido.Pendiente)
                    {
                        <span class="badge rounded-pill text-bg-warning">Pendiente</span>
                    }
                    else if (Model.Estado == EstadoPedido.Cancelado)
                    {
                        <span class="badge rounded-pill text-bg-danger">Cancelado</span>
                    }
                    else if (Model.Estado == EstadoPedido.Entregado)
                    {
                        <span class="badge rounded-pill text-bg-success">Entregado</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill text-bg-primary">@Model.Estado</span>
                    }
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <span class="text-muted small">Correo</span>
                        <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.CorreoCliente) ? Model.CorreoCliente : "No registrado")</div>
                    </div>

                    <div class="col-md-6">
                        <span class="text-muted small">Teléfono</span>
                        <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.TelefonoCliente) ? Model.TelefonoCliente : "No registrado")</div>
                    </div>

                    <div class="col-md-6">
                        <span class="text-muted small">Entrega estimada</span>
                        <div class="fw-semibold">
                            @(Model.FechaEntregaEstimada.HasValue
                                ? Model.FechaEntregaEstimada.Value.ToString("dd/MM/yyyy")
                                : "No registrada")
                        </div>
                    </div>

                    <div class="col-md-6">
                        <span class="text-muted small">Dirección</span>
                        <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.DireccionEntrega) ? Model.DireccionEntrega : "No registrada")</div>
                    </div>

                    <div class="col-md-12">
                        <span class="text-muted small">Observaciones</span>
                        <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Observaciones) ? Model.Observaciones : "Sin observaciones")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <span class="text-muted small">Total del pedido</span>
                <h2 class="fw-bold mb-0">₡@Model.Total.ToString("N2")</h2>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Cambiar estado</h5>

                <form asp-action="CambiarEstado" method="post">
                    <input type="hidden" name="pedidoId" value="@Model.Id" />

                    <div class="mb-3">
                        <select name="nuevoEstado" asp-items="estados" class="form-select rounded-pill"></select>
                    </div>

                    <button type="submit" class="btn btn-primary rounded-pill w-100">
                        Actualizar estado
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="p-4 border-bottom">
            <h5 class="fw-bold mb-0">Productos del pedido</h5>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Producto</th>
                        <th>SKU</th>
                        <th>Cantidad</th>
                        <th>Precio unitario</th>
                        <th class="text-end pe-4">Subtotal</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(detalle.ImagenUrl))
                                    {
                                        <img src="@detalle.ImagenUrl"
                                             alt="@detalle.NombreProducto"
                                             class="product-thumb" />
                                    }
                                    else
                                    {
                                        <div class="product-thumb-placeholder">
                                            @detalle.NombreProducto.Substring(0, 1).ToUpper()
                                        </div>
                                    }

                                    <div class="fw-semibold">@detalle.NombreProducto</div>
                                </div>
                            </td>

                            <td>
                                <span class="badge text-bg-light border">@detalle.CodigoSku</span>
                            </td>

                            <td>@detalle.Cantidad</td>

                            <td>₡@detalle.PrecioUnitario.ToString("N2")</td>

                            <td class="fw-bold text-end pe-4">
                                ₡@detalle.Subtotal.ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold">Subtotal</td>
                        <td class="text-end fw-bold pe-4">₡@Model.Subtotal.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td colspan="4" class="text-end fw-bold">Total</td>
                        <td class="text-end fw-bold pe-4">₡@Model.Total.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>