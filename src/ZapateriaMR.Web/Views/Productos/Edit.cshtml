@model ZapateriaMR.Web.ViewModels.Productos.ProductoEditViewModel

@{
    ViewData["Title"] = "Editar producto";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Editar producto</h1>
        <p class="text-muted mb-0">Actualiza la información comercial del producto.</p>
    </div>

    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill px-4">
        Volver
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />
            <input asp-for="ImagenActualUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control rounded-pill" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                        <textarea asp-for="Descripcion" class="form-control rounded-4" rows="4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CodigoSku" class="form-label fw-semibold"></label>
                            <input asp-for="CodigoSku" class="form-control rounded-pill" />
                            <span asp-validation-for="CodigoSku" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoriaProductoId" class="form-label fw-semibold"></label>
                            <select asp-for="CategoriaProductoId" asp-items="Model.Categorias" class="form-select rounded-pill">
                                <option value="">Seleccione una categoría</option>
                            </select>
                            <span asp-validation-for="CategoriaProductoId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Marca" class="form-label fw-semibold"></label>
                            <input asp-for="Marca" class="form-control rounded-pill" />
                            <span asp-validation-for="Marca" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Color" class="form-label fw-semibold"></label>
                            <input asp-for="Color" class="form-control rounded-pill" />
                            <span asp-validation-for="Color" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Talla" class="form-label fw-semibold"></label>
                            <input asp-for="Talla" class="form-control rounded-pill" />
                            <span asp-validation-for="Talla" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PrecioCompra" class="form-label fw-semibold"></label>
                            <input asp-for="PrecioCompra" class="form-control rounded-pill" />
                            <span asp-validation-for="PrecioCompra" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PrecioVenta" class="form-label fw-semibold"></label>
                            <input asp-for="PrecioVenta" class="form-control rounded-pill" />
                            <span asp-validation-for="PrecioVenta" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StockMinimo" class="form-label fw-semibold"></label>
                            <input asp-for="StockMinimo" class="form-control rounded-pill" />
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="Activo" class="form-check-input" />
                                <label asp-for="Activo" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="border rounded-4 p-4 bg-light h-100">
                        <h5 class="fw-bold mb-3">Imagen del producto</h5>

                        @if (!string.IsNullOrWhiteSpace(Model.ImagenActualUrl))
                        {
                            <img src="@Model.ImagenActualUrl" class="img-fluid rounded-4 mb-3 product-detail-image" />
                        }
                        else
                        {
                            <div class="product-image-empty mb-3">
                                Sin imagen
                            </div>
                        }

                        <p class="text-muted small">Sube una nueva imagen solo si deseas reemplazar la actual.</p>

                        <input asp-for="Imagen" class="form-control rounded-pill" type="file" accept=".jpg,.jpeg,.png,.webp" />
                        <span asp-validation-for="Imagen" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Guardar cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}