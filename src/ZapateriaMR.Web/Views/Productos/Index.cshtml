@model ZapateriaMR.Web.ViewModels.Productos.ProductosIndexViewModel

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Productos</h1>
        <p class="text-muted mb-0">Administra el catálogo de productos de la zapatería.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
        Nuevo producto
    </a>
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-center">
            <div class="col-md-9">
                <input asp-for="Busqueda"
                       class="form-control form-control-lg rounded-pill"
                       placeholder="Buscar por SKU, nombre o marca..." />
            </div>

            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-dark btn-lg rounded-pill">
                    Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        @if (!Model.Productos.Any())
        {
            <div class="text-center py-5">
                <h5 class="fw-semibold">No hay productos registrados</h5>
                <p class="text-muted">Crea el primer producto para comenzar a administrar el inventario.</p>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Crear producto</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Producto</th>
                            <th>SKU</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in Model.Productos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrWhiteSpace(producto.ImagenUrl))
                                        {
                                            <img src="@producto.ImagenUrl"
                                                 alt="@producto.Nombre"
                                                 class="product-thumb" />
                                        }
                                        else
                                        {
                                            <div class="product-thumb-placeholder">
                                                @producto.Nombre.Substring(0, 1).ToUpper()
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-semibold">@producto.Nombre</div>
                                            <div class="text-muted small">
                                                @producto.Marca
                                                @if (!string.IsNullOrWhiteSpace(producto.Color))
                                                {
                                                    <span> · @producto.Color</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(producto.Talla))
                                                {
                                                    <span> · Talla @producto.Talla</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge text-bg-light border">@producto.CodigoSku</span>
                                </td>

                                <td>@producto.Categoria</td>

                                <td class="fw-semibold">
                                    ₡@producto.PrecioVenta.ToString("N2")
                                </td>

                                <td>
                                    @if (producto.CantidadDisponible <= 0)
                                    {
                                        <span class="badge rounded-pill text-bg-danger">Sin stock</span>
                                    }
                                    else if (producto.CantidadDisponible <= 3)
                                    {
                                        <span class="badge rounded-pill text-bg-warning">Bajo: @producto.CantidadDisponible</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill text-bg-success">@producto.CantidadDisponible disponible</span>
                                    }
                                </td>

                                <td>
                                    @if (producto.Activo)
                                    {
                                        <span class="badge rounded-pill text-bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill text-bg-secondary">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="product-actions">
                                        <a asp-action="Details"
                                           asp-route-id="@producto.Id"
                                           class="btn-product-action action-view">
                                            Ver
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@producto.Id"
                                           class="btn-product-action action-edit">
                                            Editar
                                        </a>

                                        <form asp-action="Desactivar"
                                              asp-route-id="@producto.Id"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('¿Seguro que deseas desactivar este producto?');">
                                            <button type="submit" class="btn-product-action action-delete">
                                                Desactivar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>